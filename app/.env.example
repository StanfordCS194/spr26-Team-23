# Copy to .env.local and fill in values.
# cp .env.example .env.local

# ── Clerk (required for sign-in and protected routes) ───────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ── Database (required for report history) ──────────────────────────────────
# Use Supabase transaction pooler (port 6543) for serverless deployments.
DATABASE_URL="postgresql://user:password@host:6543/postgres?pgbouncer=true"

# Optional: only needed for `pnpm prisma:migrate` in local dev
# SHADOW_DATABASE_URL="postgresql://user:password@localhost:5432/tunnel_shadow"

# ── LLM providers (optional — more keys = more models in analysis) ───────────
# Gemini is the primary provider for prompt generation, analysis, and llms.txt.
GEMINI_API_KEY=

# Enable GPT-4o answers in multi-model analysis (standard + web search mode).
OPENAI_API_KEY=

# Enable Claude answers in multi-model analysis (standard + web search mode).
ANTHROPIC_API_KEY=

# ── Analytics (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
