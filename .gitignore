# Global ignores for this repository.

# Dependencies
node_modules/
app/node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Testing
coverage/
app/coverage/

# Next.js build outputs
.next/
out/
app/.next/
app/out/

# Production builds
build/
app/build/

# Misc
.DS_Store
*.pem

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment files
.env
.env.*
app/.env
app/.env.*

# Vercel
.vercel
app/.vercel

# TypeScript
*.tsbuildinfo
next-env.d.ts
app/next-env.d.ts
